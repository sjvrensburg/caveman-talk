#!/usr/bin/env python3
"""Decompress caveman-speak back to fluent English via any OpenAI-compatible API.

Usage:
    echo "caveman text" | caveman-decompress
    caveman-decompress "caveman text"

Prefer `pip install -e .` which registers this as a proper entry point.
This wrapper exists for environments where pip install isn't available.
"""
import sys
import os

sys.path.insert(0, os.path.join(os.path.dirname(__file__), ".."))

from caveman.translate import _cli_decompress

if __name__ == "__main__":
    _cli_decompress()
